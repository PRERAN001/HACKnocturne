# ═══════════════════════════════════════════════════════════════
#  Ghost Business Verifier — Environment Variables
#  Copy this file to .env and fill in the values.
# ═══════════════════════════════════════════════════════════════

# ── MongoDB ────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ghost-verifier

# ── Server ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── AWS Credentials (used by the backend for S3 presigned URLs) ─
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# ── S3 Bucket ──────────────────────────────────────────────────
# The bucket stores thumbnails, videos, and audit assets.
# Required prefixes: thumbnails/, videos/, audit-thumbnails/, audit-videos/
S3_BUCKET_NAME=ghost-verifier-assets

# ── Backend URL (used by the Lambda functions to POST results) ─
# Set this to the publicly-reachable URL of this backend server.
BACKEND_URL=https://your-backend.example.com
